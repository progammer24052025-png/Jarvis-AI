# ============================================================
# J.A.R.V.I.S — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your actual API keys.
# DO NOT commit .env to version control!
# ============================================================

# ── GROQ API Keys (required) ──
# Get free keys at: https://console.groq.com
# Multiple keys enable automatic rotation for rate-limit handling.
GROQ_API_KEY_1=gsk_your_key_here
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=

# ── Model Selection ──
GROQ_MODEL=llama-3.3-70b-versatile

# ── Tavily API Key (optional — for Realtime web search) ──
# Get key at: https://tavily.com
TAVILY_API_KEY=

# ── TTS Settings ──
TTS_VOICE=en-US-ChristopherNeural
TTS_RATE=+15%

# ── Assistant Identity ──
ASSISTANT_NAME=Jarvis
JARVIS_USER_TITLE=Sir
JARVIS_OWNER_NAME=

# ── CORS (optional) ──
# Comma-separated origins. Default: http://localhost:8000
# CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ── Logging (optional) ──
# Set to "json" for structured JSON logs (useful in production/Docker)
# LOG_FORMAT=text
